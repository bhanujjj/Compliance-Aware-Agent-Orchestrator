# Copy to .env and fill in your values

# Gemini / Google AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# SQLite audit log path (relative to project root)
AUDIT_DB_PATH=data/audit.db

# Policy config path
POLICY_CONFIG_PATH=sentinel/config/policy_cyber.yaml

# MCP server settings (Phase 2)
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# Logging
LOG_LEVEL=INFO
